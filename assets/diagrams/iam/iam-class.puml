@startuml iam-class
!include ../styles/reqsai-class-style.puml

title IAM Bounded Context -- Tactical Class Diagram

' ── Legend ─────────────────────────────────────────────────────────
legend top right
  |= Estereotipo                                               |= Tipo DDD                     |
  |<$REQSAI_NAVY_800><color:#FFFFFF><b> <<Aggregate Root>> </b></color>| Raiz de aggregate             |
  |<$REQSAI_GREEN_900><color:#FFFFFF><b> <<Value Object>> </b></color> | Record inmutable y validado   |
  |<$REQSAI_VIOLET_900><color:#FFFFFF><b> <<Enum>> </b></color>        | Enumeracion de dominio        |
  |<$REQSAI_BROWN_900><color:#FFFFFF><b> <<Domain Event>> </b></color> | Evento de dominio (inmutable) |
  |<$REQSAI_GRAY_700><color:#FFFFFF><b> <<Abstract>> </b></color>      | Clase abstracta Shared Kernel |
  |<$REQSAI_BLUE_800><color:#FFFFFF><b> <<Handler>> </b></color>        | Caso de uso (application)     |
  |<$REQSAI_TEAL_900><color:#FFFFFF><b> <<Port>> </b></color>           | Puerto (interface)            |
  |<$REQSAI_ORANGE_900><color:#FFFFFF><b> <<Adapter>> </b></color>      | Adaptador (infrastructure)    |
  |<$REQSAI_PURPLE_700><color:#FFFFFF><b> <<Controller>> </b></color>   | Entrada HTTP (interfaces)     |
  |<$REQSAI_LIGHTBLUE_800><color:#FFFFFF><b> <<DTO>> </b></color>       | DTO request/response          |
  |<$REQSAI_GRAY_700><color:#FFFFFF><b> <<Mapper>> </b></color>         | Mapper DTO <-> Command/Domain |
  |<$REQSAI_NEUTRAL_900><color:#FFFFFF><b> <<Security>> </b></color>    | Seguridad / filtros           |
  |<back:$REQSAI_NEUTRAL_200><b>Relacion</b>|<back:$REQSAI_NEUTRAL_200><b>Significado</b>|
  | --\\|>            | extends (herencia)                     |
  | ..>              | uses / depends on                      |
  | ..|>             | implements (interface)                 |
  | o--              | referencia por ID (cross-aggregate)    |
  | ..> <<publishes>>| evento publicado por el aggregate      |
endlegend

package "Shared Kernel" {
  abstract class AbstractAggregateRoot<T> <<Abstract>> {
    # createdAt : Instant
    # updatedAt : Instant
    # createdBy : String
    # updatedBy : String
    --
    + getIdValue() : String
    + isNew() : boolean
  }
}

package "com.kntrosoft.reqsai.iam.domain.model.aggregates" {
  class Account <<Aggregate Root>> {
    - id : AccountId
    - email : Email
    - passwordHash : String
    - status : AccountStatus
    - verificationCode : String
    - verificationCodeExpiresAt : Instant
    --
    # Account()
    + Account(email : Email, passwordHash : String)
    ..Business Methods..
    + verifyEmail(code : String, now : Instant) : void
    + changePassword(newPasswordHash : String) : void
    + suspend() : void
    + activate() : void
    + delete() : void
    + generateVerificationCode(code : String, expiresAt : Instant) : void
    ..Query Methods..
    + isPendingVerification() : boolean
    + isActive() : boolean
    + isSuspended() : boolean
    + isDeleted() : boolean
  }

  class User <<Aggregate Root>> {
    - id : UserId
    - accountId : AccountId
    - firstName : String
    - lastName : String
    - avatarUrl : String
    - preferences : UserPreferences
    --
    # User()
    + User(accountId : AccountId, firstName : String, lastName : String)
    ..Business Methods..
    + updateProfile(firstName : String, lastName : String, avatarUrl : String) : void
    + updatePreferences(preferences : UserPreferences) : void
    ..Query Methods..
    + getFullName() : String
  }

  class RefreshToken <<Aggregate Root>> {
    - id : RefreshTokenId
    - tokenHash : String
    - userId : UserId
    - status : TokenStatus
    - expiresAt : Instant
    - revokedAt : Instant
    --
    # RefreshToken()
    + RefreshToken(tokenHash : String, userId : UserId, expiresAt : Instant)
    ..Business Methods..
    + revoke(revokedAt : Instant) : void
    + rotate() : void
    ..Query Methods..
    + isValid(now : Instant) : boolean
    + isExpired(now : Instant) : boolean
  }
}

package "com.kntrosoft.reqsai.iam.domain.model.valueobjects" {
  class AccountId <<Value Object>>
  class UserId <<Value Object>>
  class RefreshTokenId <<Value Object>>

  class Email <<Value Object>> {
    - value : String
    --
    + Email(value : String)
    + {static} of(value : String) : Email
    + value() : String
  }

  class UserPreferences <<Value Object>> {
    - lastVisitedOrgId : String
    - lastVisitedProjectId : String
    --
    + UserPreferences(lastVisitedOrgId : String, lastVisitedProjectId : String)
    + lastVisitedOrgId() : String
    + lastVisitedProjectId() : String
  }

  enum AccountStatus <<Enum>> {
    PENDING_VERIFICATION
    ACTIVE
    SUSPENDED
    DELETED
  }

  enum TokenStatus <<Enum>> {
    ACTIVE
    REVOKED
    EXPIRED
  }
}

package "iam/api" {
  class AccountCreatedEvent <<Domain Event>> {
    + accountId : String
    + userId : String
    + email : String
    + occurredAt : Instant
    --
    + {static} of(accountId : String, userId : String, email : String) : AccountCreatedEvent
  }

  class EmailVerificationRequestedEvent <<Domain Event>> {
    + email : String
    + verificationCode : String
    + expirationMinutes : int
    + occurredAt : Instant
    --
    + {static} of(email : String, code : String, minutes : int) : EmailVerificationRequestedEvent
  }
}

package "com.kntrosoft.reqsai.iam.domain.model.events" {
  class AccountVerifiedEvent <<Domain Event>> {
    + accountId : String
    + occurredAt : Instant
    --
    + {static} of(accountId : String) : AccountVerifiedEvent
  }
}

package "com.kntrosoft.reqsai.iam.domain.model.exceptions" {
  abstract class EntityNotFoundException <<Abstract>>
  abstract class BusinessRuleViolationException <<Abstract>>
  abstract class AuthenticationException <<Abstract>>

  class AccountNotFoundException <<Abstract>>
  class AccountAlreadyExistsException <<Abstract>>
  class InvalidCredentialsException <<Abstract>>
  class AccountNotVerifiedException <<Abstract>>
  class CannotSuspendAccountException <<Abstract>>
  class InvalidRefreshTokenException <<Abstract>>
  class InvalidVerificationCodeException <<Abstract>>
  class UserNotFoundException <<Abstract>>
}

AccountNotFoundException         --|> EntityNotFoundException
UserNotFoundException            --|> EntityNotFoundException

AccountAlreadyExistsException    --|> BusinessRuleViolationException
AccountNotVerifiedException      --|> BusinessRuleViolationException
CannotSuspendAccountException    --|> BusinessRuleViolationException
InvalidVerificationCodeException --|> BusinessRuleViolationException

InvalidCredentialsException      --|> AuthenticationException
InvalidRefreshTokenException     --|> AuthenticationException

package "com.kntrosoft.reqsai.iam.domain.model.commands" {
  class SignUpCommand {
    + email : String
    + password : String
    + firstName : String
    + lastName : String
  }

  class SignInCommand {
    + email : String
    + password : String
  }

  class VerifyEmailCommand {
    + email : String
    + code : String
  }

  class ResendVerificationCodeCommand {
    + email : String
  }

  class ChangePasswordCommand {
    + userId : String
    + currentPassword : String
    + newPassword : String
  }

  class RefreshSessionCommand {
    + refreshToken : String
  }

  class RevokeRefreshTokenCommand {
    + refreshToken : String
  }

  class UpdateUserProfileCommand {
    + userId : String
    + firstName : String
    + lastName : String
    + avatarUrl : String
  }

  class UpdateUserPreferencesCommand {
    + userId : String
    + lastVisitedOrgId : String
    + lastVisitedProjectId : String
  }
}

package "com.kntrosoft.reqsai.iam.domain.model.queries" {
  class GetAuthenticatedUserQuery

  class GetUserByIdQuery {
    + userId : String
  }

  class GetUserByAccountIdQuery {
    + accountId : String
  }
}

' ── Application Layer (Use Cases) ───────────────────────────────────
package "com.kntrosoft.reqsai.iam.application.authentication" {
  class SignUpCommandHandler <<Handler>> {
    + handle(cmd : SignUpCommand) : AuthenticatedUserResponse
  }
  class SignInCommandHandler <<Handler>> {
    + handle(cmd : SignInCommand) : AuthenticatedUserResponse
  }
  class VerifyEmailCommandHandler <<Handler>> {
    + handle(cmd : VerifyEmailCommand) : void
  }
  class ResendVerificationCodeCommandHandler <<Handler>> {
    + handle(cmd : ResendVerificationCodeCommand) : void
  }
  class RefreshSessionCommandHandler <<Handler>> {
    + handle(cmd : RefreshSessionCommand) : AuthenticatedUserResponse
  }
  class RevokeRefreshTokenCommandHandler <<Handler>> {
    + handle(cmd : RevokeRefreshTokenCommand) : void
  }
}

package "com.kntrosoft.reqsai.iam.application.user" {
  class UpdateUserProfileCommandHandler <<Handler>> {
    + handle(cmd : UpdateUserProfileCommand) : User
  }
  class UpdateUserPreferencesCommandHandler <<Handler>> {
    + handle(cmd : UpdateUserPreferencesCommand) : User
  }
  class GetAuthenticatedUserQueryHandler <<Handler>> {
    + handle(query : GetAuthenticatedUserQuery) : User
  }
}

' ── Application Ports ───────────────────────────────────────────────
package "com.kntrosoft.reqsai.iam.application.ports" {
  interface AccountRepositoryPort <<Port>> {
    + save(account : Account) : Account
    + findById(id : String) : Optional<Account>
    + findByEmail(email : Email) : Optional<Account>
    + existsByEmail(email : Email) : boolean
  }

  interface UserRepositoryPort <<Port>> {
    + save(user : User) : User
    + findById(id : String) : Optional<User>
    + findByAccountId(accountId : AccountId) : Optional<User>
  }

  interface RefreshTokenRepositoryPort <<Port>> {
    + save(token : RefreshToken) : RefreshToken
    + findByTokenHash(hash : String) : Optional<RefreshToken>
    + deleteAllByUserId(userId : String) : void
  }

  interface TokenServicePort <<Port>> {
    + generateToken(userId : String) : String
    + validateToken(token : String) : boolean
    + getUserIdFromToken(token : String) : String
  }

  interface HashingServicePort <<Port>> {
    + encode(raw : String) : String
    + matches(raw : String, hash : String) : boolean
  }

  interface VerificationServicePort <<Port>> {
    + generateCode() : String
    + generateExpirationMinutes() : int
  }

  interface EmailNotificationServicePort <<Port>> {
    + sendVerificationEmail(to : String, code : String, expirationMinutes : int) : void
  }
}

' ── Interface Layer (HTTP) ──────────────────────────────────────────
package "com.kntrosoft.reqsai.iam.interfaces.rest.swagger" {
  interface AuthenticationController <<Controller>> {
    + signUp(request : SignUpRequest) : AuthenticatedUserResponse
    + signIn(request : SignInRequest) : AuthenticatedUserResponse
    + verifyEmail(request : VerifyEmailRequest) : void
    + resendVerificationCode(request : ResendVerificationCodeRequest) : void
    + refreshSession(request : RefreshSessionRequest) : AuthenticatedUserResponse
    + signOut(request : RevokeRefreshTokenRequest) : void
  }

  interface UserController <<Controller>> {
    + getAuthenticatedUser() : UserResponse
    + updateProfile(request : UpdateProfileRequest) : UserResponse
    + updatePreferences(request : UpdatePreferencesRequest) : UserResponse
  }
}

package "com.kntrosoft.reqsai.iam.interfaces.rest.controllers" {
  class AuthenticationControllerImpl <<Controller>>
  class UserControllerImpl <<Controller>>
}

package "com.kntrosoft.reqsai.iam.interfaces.rest.dto.request" {
  class SignUpRequest <<DTO>> {
    + email : String
    + password : String
    + firstName : String
    + lastName : String
  }

  class SignInRequest <<DTO>> {
    + email : String
    + password : String
  }

  class VerifyEmailRequest <<DTO>> {
    + email : String
    + code : String
  }

  class ResendVerificationCodeRequest <<DTO>> {
    + email : String
  }

  class RefreshSessionRequest <<DTO>> {
    + refreshToken : String
  }

  class RevokeRefreshTokenRequest <<DTO>> {
    + refreshToken : String
  }

  class UpdateProfileRequest <<DTO>> {
    + firstName : String
    + lastName : String
    + avatarUrl : String
  }

  class UpdatePreferencesRequest <<DTO>> {
    + lastVisitedOrgId : String
    + lastVisitedProjectId : String
  }
}

package "com.kntrosoft.reqsai.iam.interfaces.rest.dto.response" {
  class AuthenticatedUserResponse <<DTO>> {
    + id : String
    + email : String
    + firstName : String
    + lastName : String
    + accessToken : String
    + refreshToken : String
  }

  class UserResponse <<DTO>> {
    + id : String
    + email : String
    + firstName : String
    + lastName : String
    + avatarUrl : String
    + lastVisitedOrgId : String
    + lastVisitedProjectId : String
  }
}

package "com.kntrosoft.reqsai.iam.interfaces.rest.mappers" {
  class SignUpRequestMapper <<Mapper>> {
    + {static} toCommand(request : SignUpRequest) : SignUpCommand
  }

  class SignInRequestMapper <<Mapper>> {
    + {static} toCommand(request : SignInRequest) : SignInCommand
  }

  class UpdateProfileRequestMapper <<Mapper>> {
    + {static} toCommand(userId : String, request : UpdateProfileRequest) : UpdateUserProfileCommand
  }

  class UpdatePreferencesRequestMapper <<Mapper>> {
    + {static} toCommand(userId : String, request : UpdatePreferencesRequest) : UpdateUserPreferencesCommand
  }

  class AuthenticatedUserResponseMapper <<Mapper>> {
    + {static} toResponse(user : User, accessToken : String, refreshToken : String) : AuthenticatedUserResponse
  }

  class UserResponseMapper <<Mapper>> {
    + {static} toResponse(user : User, email : String) : UserResponse
  }
}

' ── Infrastructure Layer (Adapters) ─────────────────────────────────
package "com.kntrosoft.reqsai.iam.infrastructure.persistence.jpa" {
  class AccountRepository <<Adapter>> {
    + findByEmail(email : Email) : Optional<Account>
    + existsByEmail(email : Email) : boolean
  }

  class UserRepository <<Adapter>> {
    + findByAccountId(accountId : AccountId) : Optional<User>
  }

  class RefreshTokenRepository <<Adapter>> {
    + findByTokenHash(tokenHash : String) : Optional<RefreshToken>
    + deleteAllByUserId(userId : String) : void
  }
}

package "com.kntrosoft.reqsai.iam.infrastructure.security" {
  class WebSecurityConfiguration <<Security>>
  class BearerAuthorizationRequestFilter <<Security>>
  class UnauthorizedRequestHandlerEntryPoint <<Security>>
  class UserDetailsServiceImpl <<Security>>
}

package "com.kntrosoft.reqsai.iam.infrastructure.adapters" {
  class JwtTokenServiceAdapter <<Adapter>>
  class BCryptHashingServiceAdapter <<Adapter>>
  class OtpVerificationServiceAdapter <<Adapter>>
  class SmtpEmailNotificationAdapter <<Adapter>>
}

package "com.kntrosoft.reqsai.iam.infrastructure.events" {
  class EmailVerificationRequestedEventListener <<Adapter>>
}

package "com.kntrosoft.reqsai.iam.module" {
  class IamModuleApiImpl
}

' ── Inheritance ────────────────────────────────────────────────────
Account      --|> AbstractAggregateRoot : extends
User         --|> AbstractAggregateRoot : extends
RefreshToken --|> AbstractAggregateRoot : extends

' ── Dependencies ───────────────────────────────────────────────────
Account      ..> Email           : uses
Account      ..> AccountStatus   : uses
User         ..> UserPreferences : uses
RefreshToken ..> TokenStatus     : uses

' ── Cross-aggregate ID references ──────────────────────────────────
User         "1" o-- "1" AccountId  : accountId (reference)
RefreshToken "1" o-- "1" UserId     : userId (reference)

' ── Domain Events published ────────────────────────────────────────
Account ..> AccountCreatedEvent             : <<publishes>>
Account ..> EmailVerificationRequestedEvent : <<publishes>>
Account ..> AccountVerifiedEvent            : <<publishes>>

' ── Application dependencies ────────────────────────────────────────
SignUpCommandHandler  ..> AccountRepositoryPort
SignUpCommandHandler  ..> UserRepositoryPort
SignUpCommandHandler  ..> HashingServicePort
SignUpCommandHandler  ..> VerificationServicePort
SignUpCommandHandler  ..> EmailVerificationRequestedEvent : <<publishes>>

SignInCommandHandler  ..> AccountRepositoryPort
SignInCommandHandler  ..> UserRepositoryPort
SignInCommandHandler  ..> HashingServicePort
SignInCommandHandler  ..> TokenServicePort
SignInCommandHandler  ..> RefreshTokenRepositoryPort

VerifyEmailCommandHandler            ..> AccountRepositoryPort
ResendVerificationCodeCommandHandler ..> AccountRepositoryPort
ResendVerificationCodeCommandHandler ..> VerificationServicePort
ResendVerificationCodeCommandHandler ..> EmailVerificationRequestedEvent : <<publishes>>
RefreshSessionCommandHandler         ..> RefreshTokenRepositoryPort
RefreshSessionCommandHandler         ..> TokenServicePort
RevokeRefreshTokenCommandHandler     ..> RefreshTokenRepositoryPort

UpdateUserProfileCommandHandler     ..> UserRepositoryPort
UpdateUserPreferencesCommandHandler ..> UserRepositoryPort
GetAuthenticatedUserQueryHandler    ..> UserRepositoryPort
GetAuthenticatedUserQueryHandler    ..> AccountRepositoryPort

' ── Ports implemented by adapters ───────────────────────────────────
AccountRepository      ..|> AccountRepositoryPort
UserRepository         ..|> UserRepositoryPort
RefreshTokenRepository ..|> RefreshTokenRepositoryPort

JwtTokenServiceAdapter        ..|> TokenServicePort
BCryptHashingServiceAdapter   ..|> HashingServicePort
OtpVerificationServiceAdapter ..|> VerificationServicePort
SmtpEmailNotificationAdapter  ..|> EmailNotificationServicePort

EmailVerificationRequestedEventListener ..> EmailNotificationServicePort
EmailVerificationRequestedEventListener ..> EmailVerificationRequestedEvent

' ── HTTP wiring (contracts -> impl -> handlers) ─────────────────────
AuthenticationControllerImpl ..|> AuthenticationController
UserControllerImpl           ..|> UserController

AuthenticationControllerImpl ..> SignUpCommandHandler
AuthenticationControllerImpl ..> SignInCommandHandler
AuthenticationControllerImpl ..> VerifyEmailCommandHandler
AuthenticationControllerImpl ..> ResendVerificationCodeCommandHandler
AuthenticationControllerImpl ..> RefreshSessionCommandHandler
AuthenticationControllerImpl ..> RevokeRefreshTokenCommandHandler

UserControllerImpl ..> GetAuthenticatedUserQueryHandler
UserControllerImpl ..> UpdateUserProfileCommandHandler
UserControllerImpl ..> UpdateUserPreferencesCommandHandler

' ── DTO mapping ─────────────────────────────────────────────────────
SignUpRequestMapper            ..> SignUpRequest
SignInRequestMapper            ..> SignInRequest
UpdateProfileRequestMapper     ..> UpdateProfileRequest
UpdatePreferencesRequestMapper ..> UpdatePreferencesRequest

AuthenticatedUserResponseMapper ..> AuthenticatedUserResponse
UserResponseMapper              ..> UserResponse

AuthenticationControllerImpl ..> SignUpRequest
AuthenticationControllerImpl ..> SignInRequest
AuthenticationControllerImpl ..> VerifyEmailRequest
AuthenticationControllerImpl ..> ResendVerificationCodeRequest
AuthenticationControllerImpl ..> RefreshSessionRequest
AuthenticationControllerImpl ..> RevokeRefreshTokenRequest

UserControllerImpl ..> UpdateProfileRequest
UserControllerImpl ..> UpdatePreferencesRequest

SignUpRequestMapper        ..> SignUpCommand
SignInRequestMapper        ..> SignInCommand
UpdateProfileRequestMapper ..> UpdateUserProfileCommand
UpdatePreferencesRequestMapper ..> UpdateUserPreferencesCommand

SignUpCommandHandler  ..> SignUpCommand
SignInCommandHandler  ..> SignInCommand
VerifyEmailCommandHandler ..> VerifyEmailCommand
ResendVerificationCodeCommandHandler ..> ResendVerificationCodeCommand
RefreshSessionCommandHandler ..> RefreshSessionCommand
RevokeRefreshTokenCommandHandler ..> RevokeRefreshTokenCommand

UpdateUserProfileCommandHandler ..> UpdateUserProfileCommand
UpdateUserPreferencesCommandHandler ..> UpdateUserPreferencesCommand
GetAuthenticatedUserQueryHandler ..> GetAuthenticatedUserQuery

' ── Security dependencies ───────────────────────────────────────────
WebSecurityConfiguration ..> BearerAuthorizationRequestFilter
BearerAuthorizationRequestFilter ..> TokenServicePort
UserDetailsServiceImpl ..> AccountRepositoryPort

@enduml
